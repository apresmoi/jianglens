---
import SiteHeader from './SiteHeader.astro';
import { configuredBasePath } from '../../site.config.mjs';

const basePath = configuredBasePath();
const base = basePath ? `${basePath}/` : '/';
const pathname = Astro.url.pathname;
const current = pathname.includes('/use-with-your-agent/')
  ? 'agent'
  : pathname.includes('/episodes/')
  ? 'episodes'
  : pathname.includes('/lens/')
    ? 'lens'
    : 'about';
---

<SiteHeader
  base={base}
  current={current}
  maxWidth="100%"
  sticky={true}
  gutter="48px"
  mobileGutter="28px"
  showMobileMenu={false}
/>

<script define:vars={{ base }}>
  const evidencePattern = /\[([^\]\n]+)\]\{evidence=(?:"|“)([^"”]+)(?:"|”)\}/g;
  const episodeCache = new Map();

  function splitRefs(value) {
    return String(value || '')
      .split(/[,\s]+/)
      .map((ref) => ref.trim())
      .filter(Boolean);
  }

  function parseVideoRef(ref) {
    const match = String(ref).match(/^video:([^@]+)@transcript:v(\d+)#(seg-\d+)$/);
    if (!match) return null;
    return { slug: match[1], version: match[2], segmentId: match[3] };
  }

  async function loadEpisode(slug) {
    if (!episodeCache.has(slug)) {
      episodeCache.set(
        slug,
        fetch(`${base}data/lens/episodes/${slug}.json`).then((response) => {
          if (!response.ok) throw new Error(`Failed to load episode ${slug}`);
          return response.json();
        })
      );
    }

    return episodeCache.get(slug);
  }

  function youtubeAt(sourceUrl, start) {
    if (!sourceUrl || !Number.isFinite(Number(start))) return externalHref(sourceUrl || '#');
    const separator = sourceUrl.includes('?') ? '&' : '?';
    return externalHref(`${sourceUrl}${separator}t=${Math.floor(Number(start))}s`);
  }

  function externalHref(href) {
    if (!href) return href;
    try {
      const url = new URL(href);
      if (!['http:', 'https:'].includes(url.protocol)) return href;
      if (url.hostname === 'jianglens.com' || url.hostname === window.location.hostname) return href;
      if (!url.searchParams.has('ref')) url.searchParams.set('ref', 'jianglens.com');
      return url.toString();
    } catch {
      return href;
    }
  }

  function appendAction(parent, href, label, external = false) {
    const link = document.createElement('a');
    link.href = href;
    link.textContent = label;
    if (external) {
      link.target = '_blank';
      link.rel = 'noreferrer';
    }
    parent.append(link);
  }

  function populateMissing(container, ref) {
    const missing = document.createElement('span');
    missing.className = 'doc-evidence-ref doc-evidence-ref-missing';
    missing.textContent = ref;
    container.append(missing);
  }

  async function populateEvidence(wrap, refs) {
    const popover = wrap.querySelector('.doc-evidence-popover');
    const mark = wrap.querySelector('.doc-evidence-mark');
    const list = splitRefs(refs);
    const details = [];

    for (const ref of list) {
      const parsed = parseVideoRef(ref);
      if (!parsed) {
        details.push({ ref });
        continue;
      }

      try {
        const episode = await loadEpisode(parsed.slug);
        const segment = episode?.transcript?.find((item) => item.id === parsed.segmentId);
        details.push({ ref, episode, segment });
      } catch {
        details.push({ ref });
      }
    }

    popover.replaceChildren();
    const kicker = document.createElement('span');
    kicker.className = 'doc-evidence-kicker';
    kicker.textContent = 'Source trail';
    popover.append(kicker);

    let firstHref = '';
    for (const detail of details) {
      if (!detail.episode || !detail.segment) {
        populateMissing(popover, detail.ref);
        continue;
      }

      const episodeHref = `${base}episodes/${detail.episode.slug}/`;
      const transcriptHref = `${base}episodes/${detail.episode.slug}/transcript/#${detail.segment.id}`;
      const videoHref = youtubeAt(detail.episode.source_url, detail.segment.start);
      const title = detail.episode.read?.title || detail.episode.title || detail.episode.slug;
      const date = detail.episode.published_at || detail.episode.recorded_at || '';
      const excerpt = String(detail.segment.text || '').replace(/\s+/g, ' ').slice(0, 260);

      if (!firstHref) firstHref = transcriptHref;

      const row = document.createElement('span');
      row.className = 'doc-evidence-ref';

      const strong = document.createElement('strong');
      strong.textContent = title;
      row.append(strong);

      const meta = document.createElement('span');
      meta.className = 'doc-evidence-meta';
      meta.textContent = `${date} · ${detail.segment.time_label || detail.segment.id}`;
      row.append(meta);

      const em = document.createElement('em');
      em.textContent = `${excerpt}${excerpt.length >= 260 ? '...' : ''}`;
      row.append(em);

      const actions = document.createElement('span');
      actions.className = 'doc-evidence-actions';
      appendAction(actions, episodeHref, 'episode');
      appendAction(actions, transcriptHref, 'transcript');
      appendAction(actions, videoHref, 'video', true);
      row.append(actions);

      popover.append(row);
    }

    if (firstHref && mark instanceof HTMLAnchorElement) {
      mark.href = firstHref;
    }

    if (wrap.classList.contains('is-open')) positionEvidence(wrap);
  }

  function evidenceNode(text, refs) {
    const wrap = document.createElement('span');
    wrap.className = 'doc-evidence-wrap';
    wrap.dataset.evidenceRefs = refs;

    const mark = document.createElement('a');
    mark.className = 'doc-evidence-mark';
    mark.href = '#';
    mark.textContent = text;
    wrap.append(mark);

    const popover = document.createElement('span');
    popover.className = 'doc-evidence-popover';
    popover.role = 'tooltip';

    const loading = document.createElement('span');
    loading.className = 'doc-evidence-kicker';
    loading.textContent = 'Loading source trail';
    popover.append(loading);
    wrap.append(popover);

    wrap.dataset.evidenceHydrated = 'true';
    populateEvidence(wrap, refs);
    return wrap;
  }

  function hydrateEvidence(root) {
    root.querySelectorAll('.doc-evidence-wrap[data-evidence-refs]').forEach((wrap) => {
      if (wrap.dataset.evidenceHydrated === 'true') return;
      wrap.dataset.evidenceHydrated = 'true';
      populateEvidence(wrap, wrap.dataset.evidenceRefs);
    });
  }

  function replaceEvidenceSyntax(root) {
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent || parent.closest('code, pre, .doc-evidence-wrap')) return NodeFilter.FILTER_REJECT;
        evidencePattern.lastIndex = 0;
        return evidencePattern.test(node.nodeValue || '')
          ? NodeFilter.FILTER_ACCEPT
          : NodeFilter.FILTER_REJECT;
      },
    });

    const nodes = [];
    while (walker.nextNode()) nodes.push(walker.currentNode);

    for (const node of nodes) {
      const fragment = document.createDocumentFragment();
      const value = node.nodeValue || '';
      evidencePattern.lastIndex = 0;
      let cursor = 0;
      let match;

      while ((match = evidencePattern.exec(value))) {
        if (match.index > cursor) {
          fragment.append(document.createTextNode(value.slice(cursor, match.index)));
        }
        fragment.append(evidenceNode(match[1], match[2]));
        cursor = match.index + match[0].length;
      }

      if (cursor < value.length) {
        fragment.append(document.createTextNode(value.slice(cursor)));
      }

      node.parentNode?.replaceChild(fragment, node);
    }
  }

  function bootEvidence() {
    const content = document.querySelector('.sl-markdown-content');
    if (content?.textContent?.includes(']{evidence=')) replaceEvidenceSyntax(content);
    if (content) hydrateEvidence(content);
    setupEvidenceHover();
  }

  const evidenceCloseTimers = new WeakMap();

  function positionEvidence(wrap) {
    const mark = wrap.querySelector('.doc-evidence-mark');
    const popover = wrap.querySelector('.doc-evidence-popover');
    if (!(mark instanceof HTMLElement) || !(popover instanceof HTMLElement)) return;

    const markRect = mark.getBoundingClientRect();
    const popoverWidth = Math.min(380, Math.max(240, window.innerWidth - 32));
    const measuredHeight = popover.offsetHeight || 160;
    const left = Math.min(
      Math.max(16, markRect.left),
      Math.max(16, window.innerWidth - popoverWidth - 16)
    );
    const belowTop = markRect.bottom + 8;
    const aboveTop = markRect.top - measuredHeight - 8;
    const top =
      belowTop + measuredHeight > window.innerHeight - 12 && aboveTop >= 12
        ? aboveTop
        : Math.min(belowTop, Math.max(12, window.innerHeight - measuredHeight - 12));

    popover.style.setProperty('--evidence-popover-left', `${Math.round(left)}px`);
    popover.style.setProperty('--evidence-popover-top', `${Math.round(Math.max(12, top))}px`);
  }

  function closeEvidence(wrap) {
    const timer = evidenceCloseTimers.get(wrap);
    if (timer) window.clearTimeout(timer);
    evidenceCloseTimers.delete(wrap);
    wrap.classList.remove('is-open');
  }

  function openEvidence(wrap) {
    const timer = evidenceCloseTimers.get(wrap);
    if (timer) window.clearTimeout(timer);
    evidenceCloseTimers.delete(wrap);
    document.querySelectorAll('.doc-evidence-wrap.is-open').forEach((other) => {
      if (other !== wrap) closeEvidence(other);
    });
    positionEvidence(wrap);
    wrap.classList.add('is-open');
  }

  function scheduleEvidenceClose(wrap) {
    const timer = evidenceCloseTimers.get(wrap);
    if (timer) window.clearTimeout(timer);
    evidenceCloseTimers.set(
      wrap,
      window.setTimeout(() => {
        closeEvidence(wrap);
      }, 180)
    );
  }

  function setupEvidenceHover() {
    document.querySelectorAll('.doc-evidence-wrap').forEach((wrap) => {
      if (wrap.dataset.hoverReady === 'true') return;
      wrap.dataset.hoverReady = 'true';

      const mark = wrap.querySelector('.doc-evidence-mark');
      const popover = wrap.querySelector('.doc-evidence-popover');

      [mark, popover].forEach((element) => {
        if (!element) return;
        element.addEventListener('pointerenter', () => openEvidence(wrap));
        element.addEventListener('pointerleave', () => scheduleEvidenceClose(wrap));
      });

      wrap.addEventListener('focusin', () => openEvidence(wrap));
      wrap.addEventListener('focusout', (event) => {
        if (event.relatedTarget instanceof Node && wrap.contains(event.relatedTarget)) return;
        scheduleEvidenceClose(wrap);
      });
    });
  }

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    document.querySelectorAll('.doc-evidence-wrap.is-open').forEach(closeEvidence);
  });

  function repositionOpenEvidence() {
    document.querySelectorAll('.doc-evidence-wrap.is-open').forEach(positionEvidence);
  }

  window.addEventListener('resize', repositionOpenEvidence, { passive: true });
  window.addEventListener('scroll', repositionOpenEvidence, { passive: true });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootEvidence, { once: true });
  } else {
    bootEvidence();
  }
</script>
