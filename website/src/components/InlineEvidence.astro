---
const {
  text = '',
  marks = [],
  refs = [],
  tone = 'body',
  transcriptUrl = '',
} = Astro.props;

function transcriptSpanUrl(ref) {
  if (!transcriptUrl || !ref.segment_id) return null;
  return `${transcriptUrl}#${ref.segment_id}`;
}

function firstSentence(value) {
  const match = String(value).match(/^.{24,}?[.!?](?=\s|$)/);
  return match ? match[0] : String(value);
}

function normalizedMarks() {
  if (marks.length) return marks;
  if (!refs.length) return [];
  return [{
    text: firstSentence(text),
    refs_detail: refs,
  }];
}

function partsFor(value, sourceMarks) {
  const ranges = [];
  let searchFrom = 0;

  for (const mark of sourceMarks) {
    const quote = String(mark.text ?? '').trim();
    if (!quote) continue;

    const index = value.indexOf(quote, searchFrom);
    if (index === -1) continue;

    const end = index + quote.length;
    const previous = ranges[ranges.length - 1];
    if (previous && index < previous.end) continue;

    ranges.push({ start: index, end, mark });
    searchFrom = end;
  }

  if (!ranges.length && refs.length) {
    ranges.push({
      start: 0,
      end: value.length,
      mark: { text: value, refs_detail: refs },
    });
  }

  const parts = [];
  let cursor = 0;

  for (const range of ranges) {
    if (range.start > cursor) {
      parts.push({ text: value.slice(cursor, range.start) });
    }
    parts.push({
      text: value.slice(range.start, range.end),
      mark: range.mark,
    });
    cursor = range.end;
  }

  if (cursor < value.length) {
    parts.push({ text: value.slice(cursor) });
  }

  return parts;
}

const inlineParts = partsFor(String(text), normalizedMarks());
---

<p class:list={['inline-evidence', tone]}>
  {inlineParts.map((part) => {
    const refsDetail = part.mark?.refs_detail ?? [];
    const lensPointsDetail = part.mark?.lens_points_detail ?? [];
    const firstRef = refsDetail.find((ref) => Number.isFinite(Number(ref.start)));
    return part.mark ? (
      <span class="evidence-wrap">
        <span
          class="evidence-mark"
          role="button"
          tabindex="0"
          data-video-start={firstRef ? Math.floor(Number(firstRef.start)) : undefined}
        >
          {part.text}
        </span>
        <span class="evidence-popover" role="tooltip">
          {lensPointsDetail.length > 0 && (
            <span class="lens-links">
              <strong>Lens point</strong>
              {lensPointsDetail.map((point) => (
                point.valid ? (
                  <a class="lens-card" href={point.url}>
                    <span>{point.title || point.concept || point.doc_title}</span>
                    <em>{point.text}</em>
                  </a>
                ) : (
                  <span class="lens-card missing">
                    <span>{point.id}</span>
                    <em>{point.error}</em>
                  </span>
                )
              ))}
            </span>
          )}
          {refsDetail.length > 0 && (
            <>
              <strong>Source trail</strong>
              <span class="evidence-times">
                {refsDetail.map((ref) => {
                  const spanUrl = transcriptSpanUrl(ref);
                  return spanUrl ? (
                    <a href={spanUrl}>{ref.time_label || ref.segment_id || 'span'}</a>
                  ) : (
                    <span>{ref.time_label || ref.segment_id || 'span'}</span>
                  );
                })}
              </span>
              {refsDetail.slice(0, 2).map((ref) => (
                <em>{ref.excerpt}</em>
              ))}
            </>
          )}
        </span>
      </span>
    ) : part.text;
  })}
</p>

<style>
  .inline-evidence {
    margin: 0;
    color: #d7ccbb;
    font-size: 1.02rem;
    line-height: 1.72;
  }

  .inline-evidence.opening {
    color: #f4ead8;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.08rem, 1.45vw, 1.22rem);
    line-height: 1.58;
  }

  .evidence-wrap {
    position: relative;
    display: inline;
  }

  .evidence-mark {
    --evidence-wash: rgba(201, 167, 101, 0.12);
    --evidence-field: rgba(201, 167, 101, 0.035);
    --evidence-tick: rgba(201, 167, 101, 0.14);
    margin: 0;
    border: 0;
    border-radius: 3px;
    padding: 0 0.08em 0.04em;
    color: inherit;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    display: inline;
    font: inherit;
    line-height: inherit;
    text-align: inherit;
    text-decoration: none;
    background:
      linear-gradient(
        to top,
        var(--evidence-wash) 0,
        var(--evidence-wash) 0.48em,
        var(--evidence-field) 0.48em
      ),
      repeating-linear-gradient(
        90deg,
        transparent 0,
        transparent 0.8em,
        var(--evidence-tick) 0.8em,
        var(--evidence-tick) 0.86em,
        transparent 0.86em,
        transparent 1.7em
      );
    background-position: 0 0, 0 0;
    background-size: 100% 100%, 3.4em 100%;
    cursor: pointer;
    animation: evidenceTrace 18s linear infinite;
    transition:
      color 140ms ease,
      background-color 140ms ease,
      box-shadow 140ms ease;
  }

  .evidence-mark::after {
    content: "";
    width: 0.34em;
    height: 0.34em;
    display: inline-block;
    margin-left: 0.18em;
    border-radius: 999px;
    vertical-align: 0.12em;
    background: rgba(201, 167, 101, 0.62);
    box-shadow: 0 0 0 2px rgba(201, 167, 101, 0.1);
    animation: evidenceDot 4.8s ease-in-out infinite;
  }

  .evidence-mark:hover,
  .evidence-mark:focus-visible,
  .evidence-wrap.is-open .evidence-mark {
    --evidence-wash: rgba(201, 167, 101, 0.32);
    --evidence-field: rgba(201, 167, 101, 0.09);
    --evidence-tick: rgba(244, 234, 216, 0.18);
    color: #f4ead8;
    box-shadow: 0 0 0 1px rgba(201, 167, 101, 0.16);
    outline: none;
  }

  .evidence-mark:hover::after,
  .evidence-mark:focus-visible::after,
  .evidence-wrap.is-open .evidence-mark::after {
    background: rgba(244, 234, 216, 0.9);
    box-shadow:
      0 0 0 2px rgba(201, 167, 101, 0.18),
      0 0 12px rgba(201, 167, 101, 0.28);
  }

  .evidence-popover {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    z-index: 40;
    width: min(380px, 84vw);
    display: grid;
    gap: 8px;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    border: 1px solid rgba(244, 234, 216, 0.2);
    border-radius: 6px;
    padding: 10px;
    color: #d7ccbb;
    background: rgba(9, 10, 8, 0.98);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.42);
    transform: translateY(-3px);
    transition:
      opacity 120ms ease,
      transform 120ms ease,
      visibility 120ms step-end;
  }

  .evidence-popover::before {
    content: "";
    position: absolute;
    right: 0;
    bottom: 100%;
    left: 0;
    height: 12px;
  }

  .evidence-wrap:hover .evidence-popover,
  .evidence-wrap:focus-within .evidence-popover,
  .evidence-wrap.is-open .evidence-popover {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
    transition:
      opacity 120ms ease,
      transform 120ms ease,
      visibility 0ms;
  }

  .evidence-popover strong {
    color: #c9a765;
    font-size: 0.74rem;
    text-transform: uppercase;
  }

  .lens-links {
    display: grid;
    gap: 7px;
  }

  .lens-card {
    display: grid;
    gap: 5px;
    border: 1px solid rgba(201, 167, 101, 0.28);
    border-radius: 5px;
    padding: 9px;
    color: #f4ead8;
    text-decoration: none;
    background: rgba(201, 167, 101, 0.075);
  }

  .lens-card:hover,
  .lens-card:focus-visible {
    border-color: rgba(201, 167, 101, 0.6);
    outline: none;
  }

  .lens-card span {
    color: #c9a765;
    font-size: 0.77rem;
    font-weight: 780;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .lens-card em {
    color: #d7ccbb;
    font-size: 0.82rem;
    font-style: normal;
    line-height: 1.42;
  }

  .lens-card.missing {
    border-color: rgba(244, 234, 216, 0.16);
    color: #928b7d;
  }

  .evidence-times {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .evidence-times a,
  .evidence-times span {
    min-height: 24px;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(244, 234, 216, 0.16);
    border-radius: 4px;
    padding: 0 7px;
    color: #c9a765;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.72rem;
    text-decoration: none;
    background: rgba(244, 234, 216, 0.045);
  }

  .evidence-popover em {
    color: #928b7d;
    font-size: 0.8rem;
    font-style: normal;
    line-height: 1.42;
  }

  @media (prefers-reduced-motion: reduce) {
    .evidence-mark,
    .evidence-mark::after {
      animation: none;
    }
  }

  @keyframes evidenceTrace {
    from {
      background-position: 0 0, 0 0;
    }

    to {
      background-position: 0 0, 3.4em 0;
    }
  }

  @keyframes evidenceDot {
    0%,
    100% {
      opacity: 0.46;
      transform: scale(0.88);
    }

    45% {
      opacity: 0.9;
      transform: scale(1.14);
    }
  }
</style>
