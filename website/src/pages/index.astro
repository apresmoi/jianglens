    <script>
      const tryPromptButton = document.querySelector('[data-copy-try-prompt]');
      const tryPrompt = document.querySelector('[data-try-prompt]');

      if (tryPromptButton && tryPrompt) {
        tryPromptButton.addEventListener('click', async () => {
          await navigator.clipboard.writeText(tryPrompt.dataset.prompt ?? tryPrompt.textContent ?? '');
          tryPromptButton.textContent = 'Copied';
          window.setTimeout(() => {
            tryPromptButton.textContent = 'Copy prompt';
          }, 1800);
        });
      }
    </script>
