---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import IconLinks from '../components/IconLinks.astro';
import SiteHeader from '../components/SiteHeader.astro';
import episodeIndex from '../data/lens/episodes/index.json';
import { externalHref, pageSeo, siteConfig, structuredDataForPage } from '../../site.config.mjs';

const homeSeo = pageSeo('home');
const structuredData = structuredDataForPage('home');
const latestEpisode = episodeIndex.episodes?.[0];
const latestEpisodeHref = latestEpisode?.path ? `.${latestEpisode.path}` : './episodes/';
const latestEpisodeLabel = latestEpisode?.title
  ? `Explore the latest episode: ${latestEpisode.title}`
  : 'Explore the latest episode';
const publicSkillUrl = `${siteConfig.urls.publicOrigin}${siteConfig.paths.skill}`;
const tryPrompt = `Read ${publicSkillUrl} and analyze this with Jiang Lens: [paste a link, claim, or situation]`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <GoogleAnalytics />
    <IconLinks />
    <title>{homeSeo.title}</title>
    <meta name="description" content={homeSeo.description} />
    <meta name="keywords" content={homeSeo.keywords} />
    <meta name="author" content={siteConfig.seo.author} />
    <link rel="canonical" href={homeSeo.canonicalUrl} />
    <link rel="sitemap" href={homeSeo.sitemapUrl} />
    <link rel="alternate" type="text/markdown" href={homeSeo.skillUrl} title="Jiang Lens skill" />
    <link rel="alternate" type="text/plain" href={homeSeo.llmsUrl} title="llms.txt" />
    <link rel="alternate" type="text/plain" href={homeSeo.llmsFullUrl} title="llms-full.txt" />
    <meta property="og:title" content={homeSeo.title} />
    <meta property="og:description" content={homeSeo.description} />
    <meta property="og:type" content={homeSeo.type} />
    <meta property="og:site_name" content={siteConfig.seo.siteName} />
    <meta property="og:url" content={homeSeo.canonicalUrl} />
    <meta property="og:locale" content={siteConfig.seo.locale} />
    <meta property="og:image" content={homeSeo.imageUrl} />
    <meta property="og:image:width" content={String(homeSeo.image.width)} />
    <meta property="og:image:height" content={String(homeSeo.image.height)} />
    <meta property="og:image:alt" content={homeSeo.image.alt} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={homeSeo.title} />
    <meta name="twitter:description" content={homeSeo.description} />
    <meta name="twitter:image" content={homeSeo.imageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #070707;
        --ink: #f6efe4;
        --soft: #d7ccbb;
        --muted: #9f9688;
        --line: rgba(246, 239, 228, 0.14);
        --line-strong: rgba(246, 239, 228, 0.28);
        --paper: rgba(16, 15, 13, 0.78);
        --accent: #c85a37;
        --gold: #c9a765;
        --blue: #8aa5b9;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        margin: 0;
        min-height: 100vh;
        overflow-x: hidden;
        background:
          linear-gradient(0deg, rgba(246, 239, 228, 0.018) 1px, transparent 1px) 0 0 / 72px 72px,
          var(--bg);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      .shell {
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 18px;
      }

      .hero {
        position: relative;
        min-height: calc(100vh - 64px);
        overflow: hidden;
        border-bottom: 1px solid var(--line);
      }

      .hero-image {
        position: absolute;
        top: 0;
        right: -0vw;
        bottom: 0;
        z-index: 0;
        width: 100vw;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        opacity: 0.78;
        filter: contrast(1.04) saturate(0.94) brightness(0.84);
      }

      .hero-map {
        position: absolute;
        inset: 0;
        z-index: 1;
        width: 100%;
        height: 100%;
        opacity: 0.54;
        color: var(--gold);
        pointer-events: none;
        mix-blend-mode: screen;
      }

      .hero-map .grid-line {
        stroke: rgba(201, 167, 101, 0.055);
        stroke-width: 0.7;
      }

      .hero-map .grid-lane {
        fill: none;
        stroke: rgba(201, 167, 101, 0.12);
        stroke-width: 0.9;
        stroke-linecap: round;
        stroke-dasharray: 1 18;
        vector-effect: non-scaling-stroke;
        animation: laneDown 30s linear infinite;
      }

      .hero-map .grid-lane.up {
        opacity: 0.72;
        animation-name: laneUp;
        animation-duration: 36s;
      }

      .hero-map .chart-line {
        fill: none;
        stroke: rgba(201, 167, 101, 0.13);
        stroke-width: 1.05;
        vector-effect: non-scaling-stroke;
      }

      .hero-map .chart-line.soft {
        stroke: rgba(246, 239, 228, 0.07);
        stroke-width: 0.85;
      }

      .hero-map .path-line {
        fill: none;
        stroke: rgba(201, 167, 101, 0.28);
        stroke-width: 1.15;
        stroke-linecap: round;
        stroke-dasharray: 1 10;
        vector-effect: non-scaling-stroke;
        animation: routeDrift 26s linear infinite;
      }

      .hero-map .path-line.alt {
        animation-duration: 34s;
        animation-direction: reverse;
        opacity: 0.7;
      }

      .hero-map .node {
        fill: rgba(201, 167, 101, 0.72);
        transform-origin: center;
        animation: nodePulse 6.8s ease-in-out infinite;
      }

      .hero-map .node.dim {
        opacity: 0.42;
        animation-delay: -2.4s;
      }

      .hero-map .register {
        fill: none;
        stroke: rgba(201, 167, 101, 0.38);
        stroke-width: 1;
        vector-effect: non-scaling-stroke;
      }

      .hero-map .dust-stream {
        fill: none;
        stroke-linecap: round;
        stroke-width: 2.4;
        stroke-dasharray: 1 7;
        vector-effect: non-scaling-stroke;
        opacity: 0.54;
        animation:
          sandFlow 46s linear infinite,
          sandBreathe 10s ease-in-out infinite;
      }

      .hero-map .dust-stream.fine {
        stroke-width: 1.35;
        stroke-dasharray: 0.7 6.5;
        opacity: 0.42;
        animation-duration: 58s, 12s;
      }

      .hero-map .dust-stream.cool {
        opacity: 0.2;
        animation-duration: 64s, 14s;
        animation-direction: reverse, normal;
      }

      .hero-map .dust-stream.rust {
        opacity: 0.34;
        animation-duration: 52s, 11s;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 2;
        background-image: url("/images/jiang-grain.png");
        background-repeat: repeat;
        background-size: 256px 256px;
        pointer-events: none;
      }

      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 2;
        background:
          linear-gradient(90deg, rgba(7, 7, 7, 0.99) 0%, rgba(7, 7, 7, 0.9) 29%, rgba(7, 7, 7, 0.05) 45%, rgba(7, 7, 7, 0.15) 68%, rgba(7, 7, 7, 0.1) 100%),
          linear-gradient(180deg, rgba(7, 7, 7, 0.08) 0%, rgba(7, 7, 7, 0.01) 48%, rgba(7, 7, 7, 0.2) 100%);
        pointer-events: none;
      }

      .hero-inner {
        position: relative;
        z-index: 3;
        min-height: calc(100vh - 64px);
        display: grid;
        align-content: center;
        padding: 56px 18px 58px;
      }

      .hero-copy {
        width: min(620px, 100%);
        transform: translateY(-48px);
      }

      .kicker {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--gold);
        font-size: 0.78rem;
        font-weight: 780;
        text-transform: uppercase;
      }

      .kicker::before {
        content: "";
        width: 30px;
        height: 1px;
        background: var(--gold);
      }

      h1,
      h2,
      h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 560;
        letter-spacing: 0;
      }

      h1 {
        margin: 18px 0 0;
        font-size: 5.8rem;
        line-height: 0.9;
      }

      h1 span {
        display: block;
      }

      .lead {
        margin: 26px 0 0;
        max-width: 570px;
        color: var(--soft);
        font-size: 1.22rem;
      }

      .lead strong {
        color: var(--ink);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
      }

      .button {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line-strong);
        border-radius: 5px;
        padding: 0 16px;
        color: var(--ink);
        font-size: 0.94rem;
        font-weight: 760;
        text-decoration: none;
        background: rgba(246, 239, 228, 0.05);
      }

      .button.primary {
        border-color: var(--ink);
        background: var(--ink);
        color: #11100e;
      }

      .public-note {
        grid-column: 1 / -1;
        margin: 0;
        padding-top: 10px;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 500;
        text-align: center;
      }

      .meta-line {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 18px;
        margin-top: 34px;
        color: var(--soft);
        font-size: 0.9rem;
        font-weight: 680;
      }

      .meta-line span,
      .meta-line a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: inherit;
        text-decoration: none;
      }

      .meta-line span::before,
      .meta-line a::before {
        content: "";
        width: 6px;
        height: 6px;
        flex: 0 0 auto;
        border-radius: 50%;
        background: var(--accent);
      }

      .meta-line a:hover,
      .meta-line a:focus-visible {
        color: var(--ink);
        outline: none;
      }

      .section {
        padding: 78px 0;
        border-bottom: 1px solid var(--line);
      }

      .quick-start {
        position: absolute;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 4;
        border-top: 1px solid rgba(246, 239, 228, 0.12);
        background:
          linear-gradient(90deg, rgba(201, 167, 101, 0.09), transparent 55%),
          rgba(9, 10, 8, 0.58);
        backdrop-filter: blur(10px);
      }

      .quick-start-inner {
        display: grid;
        grid-template-columns: minmax(0, 0.56fr) minmax(0, 1fr);
        gap: 16px 24px;
        align-items: center;
        padding-top: 18px;
        padding-bottom: 14px;
      }

      .quick-start-label {
        display: block;
        color: var(--gold);
        font-size: 0.74rem;
        font-weight: 780;
        text-transform: uppercase;
      }

      .quick-start h2 {
        margin: 6px 0 0;
        max-width: 440px;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 1rem;
        font-weight: 680;
        line-height: 1.35;
      }

      .quick-start-row {
        min-width: 0;
        display: flex;
        align-items: stretch;
        border: 1px solid rgba(246, 239, 228, 0.18);
        border-radius: 6px;
        background: rgba(7, 7, 7, 0.76);
        overflow: hidden;
      }

      .quick-start-row code {
        min-width: 0;
        flex: 1 1 auto;
        padding: 10px 14px;
        color: var(--soft);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 0.82rem;
        line-height: 1.45;
      }

      .quick-copy {
        flex: 0 0 auto;
        border: 0;
        border-left: 1px solid rgba(246, 239, 228, 0.16);
        padding: 0 14px;
        color: var(--ink);
        font: inherit;
        font-size: 0.84rem;
        font-weight: 760;
        background: rgba(246, 239, 228, 0.08);
        cursor: pointer;
      }

      .quick-copy:hover,
      .quick-copy:focus-visible {
        background: rgba(201, 167, 101, 0.2);
        outline: none;
      }

      .section-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 72px;
        align-items: start;
      }

      .section h2 {
        margin: 0;
        max-width: 560px;
        font-size: 3.25rem;
        line-height: 1;
      }

      .section-intro {
        margin: 18px 0 0;
        max-width: 520px;
        color: var(--muted);
        font-size: 1.04rem;
      }

      .agent-lines {
        display: grid;
        gap: 0;
        border-top: 1px solid var(--line);
      }

      .agent-line {
        display: grid;
        grid-template-columns: 150px minmax(0, 1fr);
        gap: 26px;
        border-bottom: 1px solid var(--line);
        padding: 22px 0;
      }

      .agent-line strong {
        color: var(--gold);
        font-size: 0.92rem;
        text-transform: uppercase;
      }

      .agent-line p {
        margin: 0;
        color: var(--soft);
      }

      .ledger {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 26px;
        margin-top: 38px;
      }

      .ledger-item {
        border-top: 1px solid var(--line-strong);
        padding-top: 18px;
      }

      .ledger-item span {
        color: var(--accent);
        font-weight: 780;
      }

      .ledger-item h3 {
        margin: 12px 0 10px;
        font-size: 1.8rem;
        line-height: 1;
      }

      .ledger-item p {
        margin: 0;
        color: var(--muted);
      }

      .quote-band {
        padding: 76px 0;
      }

      .quote-band blockquote {
        margin: 0;
        max-width: 960px;
        color: var(--ink);
        font-family: Georgia, "Times New Roman", serif;
        font-size: 3.2rem;
        line-height: 1.05;
      }

      .quote-band p {
        max-width: 680px;
        margin: 22px 0 0;
        color: var(--muted);
      }

      .footer {
        padding: 28px 0 46px;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px 20px;
        border-top: 1px solid var(--line);
        padding-top: 22px;
      }

      .footer p {
        margin: 0;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
      }

      .footer a {
        color: var(--soft);
        font-weight: 680;
        text-decoration-color: rgba(201, 167, 101, 0.58);
        text-underline-offset: 0.22em;
      }

      .footer a:hover,
      .footer a:focus-visible {
        color: var(--ink);
        outline: none;
      }

      @media (max-width: 1020px) {
        .hero-image {
          right: -15vw;
          width: 150vw;
          opacity: 0.64;
        }

        h1 {
          font-size: 4.8rem;
        }

        .section-grid {
          grid-template-columns: 1fr;
          gap: 34px;
        }

        .ledger {
          grid-template-columns: 1fr;
        }

      }

      @media (max-width: 720px) {
        .shell {
          padding-right: 14px;
          padding-left: 14px;
        }

        .hero,
        .hero-inner {
          min-height: calc(100svh - 64px);
        }

        .hero-inner {
          padding-top: 32px;
          padding-bottom: 236px;
        }

        .hero-image {
          right: -105vw;
          width: 220vw;
          opacity: 0.32;
        }

        .hero-map {
          opacity: 0.34;
        }

        h1 {
          font-size: 3.25rem;
        }

        .hero-copy {
          transform: translateY(-24px);
        }

        .lead {
          font-size: 1.02rem;
        }

        .button {
          width: 100%;
          min-height: 44px;
        }

        .section {
          padding: 56px 0;
        }

        .quick-start {
          bottom: 0;
        }

        .meta-line {
          display: none;
        }

        .quick-start-inner {
          grid-template-columns: 1fr;
          gap: 10px;
          padding-top: 14px;
          padding-bottom: 12px;
        }

        .quick-start-row {
          display: grid;
        }

        .quick-start h2 {
          margin-top: 4px;
          font-size: 0.96rem;
        }

        .quick-start-row code {
          padding: 10px 12px;
          font-size: 0.78rem;
        }

        .quick-copy {
          min-height: 38px;
          border-top: 1px solid rgba(246, 239, 228, 0.16);
          border-left: 0;
        }

        .public-note {
          padding-top: 8px;
          font-size: 0.78rem;
        }

        .section h2,
        .quote-band blockquote {
          font-size: 2.25rem;
        }

        .agent-line {
          grid-template-columns: 1fr;
          gap: 8px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-map .grid-lane,
        .hero-map .path-line,
        .hero-map .node,
        .hero-map .dust-stream {
          animation: none;
        }
      }

      @keyframes laneDown {
        from {
          stroke-dashoffset: 0;
        }

        to {
          stroke-dashoffset: 220;
        }
      }

      @keyframes laneUp {
        from {
          stroke-dashoffset: 0;
        }

        to {
          stroke-dashoffset: -220;
        }
      }

      @keyframes routeDrift {
        from {
          stroke-dashoffset: 0;
        }

        to {
          stroke-dashoffset: -220;
        }
      }

      @keyframes nodePulse {
        0%,
        100% {
          opacity: 0.42;
          transform: scale(0.92);
        }

        45% {
          opacity: 0.9;
          transform: scale(1.14);
        }
      }

      @keyframes sandFlow {
        from {
          stroke-dashoffset: 0;
        }

        to {
          stroke-dashoffset: -420;
        }
      }

      @keyframes sandBreathe {
        0%,
        100% {
          opacity: 0.38;
        }

        48% {
          opacity: 0.68;
        }
      }

    </style>
  </head>
  <body>
    <SiteHeader base="./" current="home" />

    <main>
      <section class="hero" aria-label="Predictive History lens overview">
        <img
          class="hero-image"
          src="./images/jiang-xueqin-hero.png"
          alt="Professor Jiang Xueqin seated at a microphone during an interview"
          width="1731"
          height="909"
        />
        <svg
          class="hero-map"
          viewBox="0 0 1600 900"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="hero-sand-gold" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="rgba(201, 167, 101, 0)" />
              <stop offset="0.34" stop-color="rgba(201, 167, 101, 0.72)" />
              <stop offset="0.62" stop-color="rgba(244, 234, 216, 0.5)" />
              <stop offset="1" stop-color="rgba(201, 167, 101, 0)" />
            </linearGradient>
            <linearGradient id="hero-sand-rust" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="rgba(159, 95, 68, 0)" />
              <stop offset="0.44" stop-color="rgba(201, 90, 55, 0.58)" />
              <stop offset="1" stop-color="rgba(159, 95, 68, 0)" />
            </linearGradient>
            <linearGradient id="hero-sand-cool" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="rgba(74, 154, 158, 0)" />
              <stop offset="0.5" stop-color="rgba(74, 154, 158, 0.52)" />
              <stop offset="1" stop-color="rgba(74, 154, 158, 0)" />
            </linearGradient>
            <clipPath id="hero-map-frame">
              <rect x="0" y="0" width="1600" height="900" />
            </clipPath>
          </defs>
          <g clip-path="url(#hero-map-frame)">
            <path class="dust-stream" stroke="url(#hero-sand-gold)" d="M-70 608C210 566 354 612 548 684C748 758 942 768 1110 708C1266 652 1410 574 1680 612" />
            <path class="dust-stream fine rust" stroke="url(#hero-sand-rust)" d="M-80 532C112 490 248 530 390 602C558 688 692 718 870 674C1038 632 1164 540 1348 520C1488 504 1580 552 1680 596" />
            <path class="dust-stream fine cool" stroke="url(#hero-sand-cool)" d="M470 150C608 288 730 362 892 374C1068 388 1194 304 1378 278C1490 262 1574 288 1680 342" />
            <path class="dust-stream fine" stroke="url(#hero-sand-gold)" d="M660 840C660 692 704 560 782 424C850 306 852 218 790 96" />
            <g opacity="0.72">
              <path class="grid-line" d="M0 70H1600M0 140H1600M0 210H1600M0 280H1600M0 350H1600M0 420H1600M0 490H1600M0 560H1600M0 630H1600M0 700H1600M0 770H1600M0 840H1600" />
            </g>
            <g opacity="0.5">
              <path class="grid-lane" d="M140 -80V980" />
              <path class="grid-lane up" d="M292 -80V980" />
              <path class="grid-lane" d="M444 -80V980" />
              <path class="grid-lane up" d="M596 -80V980" />
              <path class="grid-lane" d="M748 -80V980" />
              <path class="grid-lane up" d="M900 -80V980" />
              <path class="grid-lane" d="M1052 -80V980" />
              <path class="grid-lane up" d="M1204 -80V980" />
              <path class="grid-lane" d="M1356 -80V980" />
              <path class="grid-lane up" d="M1508 -80V980" />
            </g>

            <path class="chart-line soft" d="M-50 116C105 46 172 112 300 78C463 35 531 104 696 78C825 58 930 -10 1098 46C1230 90 1348 43 1648 24" />
            <path class="chart-line soft" d="M1120 120C1190 160 1305 158 1395 138C1476 120 1538 150 1624 208" />
            <path class="chart-line soft" d="M1260 205C1315 244 1386 263 1466 247C1534 234 1582 255 1640 296" />
            <path class="chart-line" d="M730 292C812 280 866 279 934 294C1025 313 1077 356 1140 420C1210 492 1280 532 1410 514C1494 502 1556 526 1644 568" />
            <path class="chart-line" d="M-62 515C150 550 293 608 484 667C640 715 776 744 942 748C1120 752 1308 704 1662 690" />
            <path class="chart-line soft" d="M660 820C648 650 682 528 755 390C802 300 794 221 747 142" />

