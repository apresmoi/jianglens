---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import IconLinks from '../components/IconLinks.astro';
import SiteHeader from '../components/SiteHeader.astro';
import episodeIndex from '../data/lens/episodes/index.json';
import { pageSeo, siteConfig, structuredDataForPage } from '../../site.config.mjs';

const homeSeo = pageSeo('home');
const structuredData = structuredDataForPage('home');
const latestEpisode = episodeIndex.episodes?.[0];
const latestEpisodeHref = latestEpisode?.path ? `.${latestEpisode.path}` : './episodes/';
const latestEpisodeLabel = latestEpisode?.title
  ? `Explore the latest episode: ${latestEpisode.title}`
  : 'Explore the latest episode';
const publicSkillUrl = `${siteConfig.urls.publicOrigin}${siteConfig.paths.skill}`;
const tryPrompt = `Read ${publicSkillUrl}, then use Jiang Lens to analyze this: [paste a news link, speech, claim, or situation]`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <GoogleAnalytics />
    <IconLinks />
    <title>{homeSeo.title}</title>
    <meta name="description" content={homeSeo.description} />
    <meta name="keywords" content={homeSeo.keywords} />
    <meta name="author" content={siteConfig.seo.author} />
    <link rel="canonical" href={homeSeo.canonicalUrl} />
    <link rel="sitemap" href={homeSeo.sitemapUrl} />
    <link rel="alternate" type="text/markdown" href={homeSeo.skillUrl} title="Jiang Lens skill" />
    <link rel="alternate" type="text/plain" href={homeSeo.llmsUrl} title="llms.txt" />
    <link rel="alternate" type="text/plain" href={homeSeo.llmsFullUrl} title="llms-full.txt" />
    <meta property="og:title" content={homeSeo.title} />
    <meta property="og:description" content={homeSeo.description} />
    <meta property="og:type" content={homeSeo.type} />
    <meta property="og:site_name" content={siteConfig.seo.siteName} />
    <meta property="og:url" content={homeSeo.canonicalUrl} />
    <meta property="og:locale" content={siteConfig.seo.locale} />
    <meta property="og:image" content={homeSeo.imageUrl} />
    <meta property="og:image:width" content={String(homeSeo.image.width)} />
    <meta property="og:image:height" content={String(homeSeo.image.height)} />
    <meta property="og:image:alt" content={homeSeo.image.alt} />
    <meta name="twitter:card" content={siteConfig.seo.twitterCard} />
    <meta name="twitter:title" content={homeSeo.title} />
    <meta name="twitter:description" content={homeSeo.description} />
    <meta name="twitter:image" content={homeSeo.imageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #070707;
        --ink: #f6efe4;
        --soft: #d7ccbb;
        --muted: #9f9688;
        --line: rgba(246, 239, 228, 0.14);
        --line-strong: rgba(246, 239, 228, 0.28);
        --paper: rgba(16, 15, 13, 0.78);
        --accent: #c85a37;
        --gold: #c9a765;
        --blue: #8aa5b9;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        margin: 0;
        min-height: 100vh;
        overflow-x: hidden;
        background:
          linear-gradient(90deg, rgba(246, 239, 228, 0.028) 1px, transparent 1px) 0 0 / 72px 72px,
          linear-gradient(0deg, rgba(246, 239, 228, 0.018) 1px, transparent 1px) 0 0 / 72px 72px,
          var(--bg);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      .shell {
        width: 100%;
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 18px;
      }

      .hero {
        position: relative;
        min-height: calc(100vh - 64px);
        overflow: hidden;
        border-bottom: 1px solid var(--line);
      }

      .hero-image {
        position: absolute;
        top: 0;
        right: -0vw;
        bottom: 0;
        z-index: 0;
        width: 100vw;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        opacity: 0.78;
        filter: contrast(1.04) saturate(0.94) brightness(0.84);
      }

      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          linear-gradient(90deg, rgba(7, 7, 7, 0.99) 0%, rgba(7, 7, 7, 0.9) 29%, rgba(7, 7, 7, 0.05) 45%, rgba(7, 7, 7, 0.15) 68%, rgba(7, 7, 7, 0.1) 100%),
          linear-gradient(180deg, rgba(7, 7, 7, 0.08) 0%, rgba(7, 7, 7, 0.01) 48%, rgba(7, 7, 7, 0.2) 100%);
        pointer-events: none;
      }

      .hero-inner {
        position: relative;
        z-index: 2;
        min-height: calc(100vh - 64px);
        display: grid;
        align-content: center;
        padding: 56px 18px 58px;
      }

      .hero-copy {
        width: min(620px, 100%);
      }

      .kicker {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--gold);
        font-size: 0.78rem;
        font-weight: 780;
        text-transform: uppercase;
      }

      .kicker::before {
        content: "";
        width: 30px;
        height: 1px;
        background: var(--gold);
      }

      h1,
      h2,
      h3 {
        font-family: Georgia, "Times New Roman", serif;
        font-weight: 560;
        letter-spacing: 0;
      }

      h1 {
        margin: 18px 0 0;
        font-size: 5.8rem;
        line-height: 0.9;
      }

      h1 span {
        display: block;
      }

      .lead {
        margin: 26px 0 0;
        max-width: 570px;
        color: var(--soft);
        font-size: 1.22rem;
      }

      .lead strong {
        color: var(--ink);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
      }

      .button {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line-strong);
        border-radius: 5px;
        padding: 0 16px;
        color: var(--ink);
        font-size: 0.94rem;
        font-weight: 760;
        text-decoration: none;
        background: rgba(246, 239, 228, 0.05);
      }

      .button.primary {
        border-color: var(--ink);
        background: var(--ink);
        color: #11100e;
      }

      .public-note {
        margin: 0;
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 500;
        text-align: center;
      }

      .fold-footer {
        position: absolute;
        right: 0;
        bottom: 30px;
        left: 0;
        z-index: 3;
        pointer-events: none;
      }

      .meta-line {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 18px;
        margin-top: 34px;
        color: var(--soft);
        font-size: 0.9rem;
        font-weight: 680;
      }

      .meta-line span,
      .meta-line a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: inherit;
        text-decoration: none;
      }

      .meta-line span::before,
      .meta-line a::before {
        content: "";
        width: 6px;
        height: 6px;
        flex: 0 0 auto;
        border-radius: 50%;
        background: var(--accent);
      }

      .meta-line a:hover,
      .meta-line a:focus-visible {
        color: var(--ink);
        outline: none;
      }

      .section {
        padding: 78px 0;
        border-bottom: 1px solid var(--line);
      }

      .quick-start {
        position: absolute;
        right: 0;
        bottom: 64px;
        left: 0;
        z-index: 3;
        border-top: 1px solid var(--line);
        background:
          linear-gradient(90deg, rgba(201, 167, 101, 0.09), transparent 55%),
          rgba(9, 10, 8, 0.58);
        backdrop-filter: blur(10px);
      }

      .quick-start-inner {
        display: grid;
        grid-template-columns: minmax(0, 0.56fr) minmax(0, 1fr);
        gap: 24px;
        align-items: center;
        padding-top: 16px;
        padding-bottom: 16px;
      }

      .quick-start-label {
        display: block;
        color: var(--gold);
        font-size: 0.74rem;
        font-weight: 780;
        text-transform: uppercase;
      }

      .quick-start h2 {
        margin: 6px 0 0;
        max-width: 440px;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 1rem;
        font-weight: 680;
        line-height: 1.35;
      }

      .quick-start-row {
        min-width: 0;
        display: flex;
        align-items: stretch;
        border: 1px solid rgba(246, 239, 228, 0.18);
        border-radius: 6px;
        background: rgba(7, 7, 7, 0.76);
        overflow: hidden;
      }

      .quick-start-row code {
        min-width: 0;
        flex: 1 1 auto;
        padding: 10px 14px;
        color: var(--soft);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        font-size: 0.82rem;
        line-height: 1.45;
      }

      .quick-copy {
        flex: 0 0 auto;
        border: 0;
        border-left: 1px solid rgba(246, 239, 228, 0.16);
        padding: 0 14px;
        color: var(--ink);
        font: inherit;
        font-size: 0.84rem;
        font-weight: 760;
        background: rgba(246, 239, 228, 0.08);
        cursor: pointer;
      }

      .quick-copy:hover,
      .quick-copy:focus-visible {
        background: rgba(201, 167, 101, 0.2);
        outline: none;
      }

      .section-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 72px;
        align-items: start;
      }

      .section h2 {
        margin: 0;
        max-width: 560px;
        font-size: 3.25rem;
        line-height: 1;
      }

      .section-intro {
        margin: 18px 0 0;
        max-width: 520px;
        color: var(--muted);
        font-size: 1.04rem;
      }

      .agent-lines {
        display: grid;
        gap: 0;
        border-top: 1px solid var(--line);
      }

      .agent-line {
        display: grid;
        grid-template-columns: 150px minmax(0, 1fr);
        gap: 26px;
        border-bottom: 1px solid var(--line);
        padding: 22px 0;
      }

      .agent-line strong {
        color: var(--gold);
        font-size: 0.92rem;
        text-transform: uppercase;
      }

      .agent-line p {
        margin: 0;
        color: var(--soft);
      }

      .ledger {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 26px;
        margin-top: 38px;
      }

      .ledger-item {
        border-top: 1px solid var(--line-strong);
        padding-top: 18px;
      }

      .ledger-item span {
        color: var(--accent);
        font-weight: 780;
      }

      .ledger-item h3 {
        margin: 12px 0 10px;
        font-size: 1.8rem;
        line-height: 1;
      }

      .ledger-item p {
        margin: 0;
        color: var(--muted);
      }

      .quote-band {
        padding: 76px 0;
      }

      .quote-band blockquote {
        margin: 0;
        max-width: 960px;
        color: var(--ink);
        font-family: Georgia, "Times New Roman", serif;
        font-size: 3.2rem;
        line-height: 1.05;
      }

      .quote-band p {
        max-width: 680px;
        margin: 22px 0 0;
        color: var(--muted);
      }

      .footer {
        padding: 28px 0 46px;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 12px 20px;
        border-top: 1px solid var(--line);
        padding-top: 22px;
      }

      .footer p {
        margin: 0;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
      }

      .footer a {
        color: var(--soft);
        font-weight: 680;
        text-decoration-color: rgba(201, 167, 101, 0.58);
        text-underline-offset: 0.22em;
      }

      .footer a:hover,
      .footer a:focus-visible {
        color: var(--ink);
        outline: none;
      }

      @media (max-width: 1020px) {
        .hero-image {
          right: -15vw;
          width: 150vw;
          opacity: 0.64;
        }

        h1 {
          font-size: 4.8rem;
        }

        .section-grid {
          grid-template-columns: 1fr;
          gap: 34px;
        }

        .ledger {
          grid-template-columns: 1fr;
        }

      }

      @media (max-width: 720px) {
        .shell {
          padding-right: 14px;
          padding-left: 14px;
        }

        .hero,
        .hero-inner {
          min-height: calc(100svh - 64px);
        }

        .hero-inner {
          padding-top: 32px;
          padding-bottom: 236px;
        }

        .hero-image {
          right: -105vw;
          width: 220vw;
          opacity: 0.32;
        }

        h1 {
          font-size: 3.25rem;
        }

        .lead {
          font-size: 1.02rem;
        }

        .button {
          width: 100%;
          min-height: 44px;
        }

        .section {
          padding: 56px 0;
        }

        .quick-start {
          bottom: 76px;
        }

        .quick-start-inner {
          grid-template-columns: 1fr;
          gap: 14px;
          padding-top: 18px;
          padding-bottom: 18px;
        }

        .quick-start-row {
          display: grid;
        }

        .quick-copy {
          min-height: 42px;
          border-top: 1px solid rgba(246, 239, 228, 0.16);
          border-left: 0;
        }

        .section h2,
        .quote-band blockquote {
          font-size: 2.25rem;
        }

        .agent-line {
          grid-template-columns: 1fr;
          gap: 8px;
        }
      }
    </style>
  </head>
  <body>
    <SiteHeader base="./" current="home" />

    <main>
      <section class="hero" aria-label="Predictive History lens overview">
        <img
          class="hero-image"
          src="./images/jiang-xueqin-hero.png"
          alt="Professor Jiang Xueqin seated at a microphone during an interview"
          width="1731"
          height="909"
        />
        <div class="shell hero-inner">
          <div class="hero-copy">
            <span class="kicker">Agent-run open research</span>
            <h1><span>Predictive</span><span>History Lens</span></h1>
            <p class="lead">
              We analyze Jiang Xueqin's lectures, interviews, and writing to distill the concepts, chronology, and source-grounded readings behind the Predictive History world model for readers, ChatGPT, Claude, and other agents.
            </p>
            <div class="hero-actions">
              <a class="button primary" href={latestEpisodeHref} aria-label={latestEpisodeLabel}>Explore the latest episode</a>
              <a class="button" href="./lens/">Explore the lens</a>
            </div>
            <div class="meta-line" aria-label="Project qualities">
              <span>run by agents</span>
              <a href={siteConfig.urls.repository} target="_blank" rel="noopener noreferrer">open repository</a>
              <a href="https://www.youtube.com/@PredictiveHistory" target="_blank" rel="noopener noreferrer">source-grounded</a>
            </div>
          </div>
        </div>
        <section class="quick-start" aria-labelledby="try-it-title">
          <div class="shell quick-start-inner">
            <div>
              <span class="quick-start-label">Try it in 60 seconds</span>
              <h2 id="try-it-title">Paste this into ChatGPT or Claude, then add a live question, link, or claim.</h2>
            </div>
            <div class="quick-start-row">
              <code data-try-prompt data-prompt={tryPrompt}>{tryPrompt}</code>
              <button class="quick-copy" type="button" data-copy-try-prompt>Copy prompt</button>
            </div>
          </div>
        </section>
        <div class="shell fold-footer" aria-label="Project status">
          <p class="public-note">Independent research project. Not an official Jiang Xueqin or Predictive History publication.</p>
        </div>
      </section>

      <section class="section">
        <div class="shell section-grid">
          <div>
            <h2>A research site run by agents, visible to humans.</h2>
            <p class="section-intro">
              Agents do the repetitive work around the clock: ingesting lectures, cleaning transcripts, proposing concept readings, checking provenance, tracking chronology, and keeping the public site synchronized with the repository.
            </p>
          </div>
          <div class="agent-lines" aria-label="Agent workflow">
            <div class="agent-line">
              <strong>Ingest</strong>
              <p>New sources become stable, addressable records instead of loose links or memory.</p>
            </div>
            <div class="agent-line">
              <strong>Ground</strong>
              <p>Important claims are tied to exact passages, timestamps, and source versions.</p>
            </div>
            <div class="agent-line">
              <strong>Review</strong>
              <p>Agents separate Jiang-sourced material from interpretation, commentary, and contradiction.</p>
            </div>
            <div class="agent-line">
              <strong>Publish</strong>
              <p>The website renders readable episodes, concept pages, provenance data, and agent-readable artifacts.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="shell">
          <div class="section-grid">
            <div>
              <h2>The lens stays useful because the trail stays open.</h2>
              <p class="section-intro">
                Predictive History is treated as a system to study, not a persona to imitate. The public interface should make strong readings possible while preserving uncertainty.
              </p>
            </div>
            <div class="ledger" aria-label="Public surfaces">
              <div class="ledger-item">
                <span>01</span>
                <h3>Canon</h3>
                <p>World model, actors, forces, mechanics, analogies, and prediction protocol.</p>
              </div>
              <div class="ledger-item">
                <span>02</span>
                <h3>Ledger</h3>
                <p>Forecast-like claims tracked with source, horizon, conditions, and outcomes.</p>
              </div>
              <div class="ledger-item">
                <span>03</span>
                <h3>Commentary</h3>
                <p>Challenges and counter-readings remain attached without rewriting the canon.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="shell quote-band">
        <blockquote>
          The goal is not to make an oracle. The goal is to make the reasoning machinery inspectable.
        </blockquote>
        <p>
          Jiang Lens is the working substrate for that: a repo, a public site, and a set of agents that keep the source trail alive as the corpus grows.
        </p>
      </section>
    </main>

    <footer class="shell footer">
      <div class="footer-inner">
        <p>Independent research project. Not an official Jiang Xueqin or Predictive History publication.</p>
        <div class="footer-links" aria-label="Project links">
          <a href={siteConfig.credits.builderUrl}>Built by {siteConfig.credits.builderName}</a>
          <a href={siteConfig.credits.maintainerUrl} rel="me">X / {siteConfig.credits.maintainerHandle}</a>
          <a href={siteConfig.credits.repositoryUrl}>GitHub repo</a>
        </div>
      </div>
    </footer>
    <script>
      const tryPromptButton = document.querySelector('[data-copy-try-prompt]');
      const tryPrompt = document.querySelector('[data-try-prompt]');

      if (tryPromptButton && tryPrompt) {
        tryPromptButton.addEventListener('click', async () => {
          await navigator.clipboard.writeText(tryPrompt.dataset.prompt ?? tryPrompt.textContent ?? '');
          tryPromptButton.textContent = 'Copied';
          window.setTimeout(() => {
            tryPromptButton.textContent = 'Copy prompt';
          }, 1800);
        });
      }
    </script>
  </body>
</html>
