---
import { readFile } from 'node:fs/promises';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import IconLinks from '../components/IconLinks.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { absoluteUrl, siteConfig } from '../../site.config.mjs';

const title = 'Jiang Lens Skill | Agent Instructions';
const description = 'HTML-first Jiang Lens skill with the full canonical instruction text, topic routes, source readings, transcript anchors, and citation-safe mirrors.';
const canonicalUrl = absoluteUrl(siteConfig.paths.skillPage);
const promptText = `Read ${canonicalUrl} and analyze this with Jiang Lens: [paste a link, claim, or situation]`;
const skillMarkdown = await readFile('public/skill.md', 'utf8');
const topicExamples = [
  ['Knights Templar / templars', '/topics/knights-templar/'],
  ['Trump', '/topics/trump/'],
  ['Newton', '/topics/newton/'],
  ['Freemasons', '/topics/freemasons/'],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <GoogleAnalytics />
    <IconLinks />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/plain" href={absoluteUrl(siteConfig.paths.skillText)} title="Jiang Lens skill text" />
    <link rel="alternate" type="text/markdown" href={absoluteUrl(siteConfig.paths.skillMarkdown)} title="Jiang Lens skill Markdown" />
    <link rel="alternate" type="text/plain" href={absoluteUrl(siteConfig.paths.llms)} title="llms.txt" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      name: title,
      description,
      url: canonicalUrl,
      isPartOf: {
        '@type': 'WebSite',
        name: siteConfig.name,
        url: siteConfig.urls.publicOrigin,
      },
      about: ['Jiang Lens', 'Jiang Xueqin', 'Predictive History', 'AI agents', 'source-grounded citation'],
    })} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #080908;
        --ink: #f4ead8;
        --soft: #d1c6b4;
        --muted: #928b7d;
        --line: rgba(244, 234, 216, 0.14);
        --line-strong: rgba(244, 234, 216, 0.28);
        --panel: rgba(244, 234, 216, 0.045);
        --accent: #c85a37;
        --gold: #c9a765;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          linear-gradient(0deg, rgba(244, 234, 216, 0.018) 1px, transparent 1px) 0 0 / 72px 72px,
          var(--bg);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.55;
      }

      a {
        color: inherit;
      }

      main {
        width: min(1100px, calc(100% - 36px));
        margin: 0 auto;
        padding: 50px 0 76px;
      }

      .hero {
        max-width: 860px;
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--gold);
        font-size: 0.76rem;
        font-weight: 760;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        font-size: clamp(2.25rem, 5vw, 4rem);
        font-weight: 560;
        line-height: 1.03;
        letter-spacing: 0;
      }

      .lead {
        max-width: 760px;
        margin: 18px 0 0;
        color: var(--soft);
        font-size: 1.04rem;
      }

      .prompt {
        margin: 28px 0 0;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 16px;
        background: rgba(0, 0, 0, 0.22);
      }

      .prompt code {
        display: block;
        overflow-wrap: anywhere;
        color: var(--ink);
        font: 0.95rem/1.55 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        margin: 34px 0 0;
      }

      section {
        border-top: 1px solid var(--line);
        padding-top: 24px;
      }

      .panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
        background: var(--panel);
      }

      h2 {
        margin: 0 0 12px;
        font-size: 1rem;
        letter-spacing: 0;
      }

      p {
        margin: 0;
        color: var(--soft);
      }

      ol,
      ul {
        margin: 0;
        padding-left: 1.2rem;
        color: var(--soft);
      }

      li + li {
        margin-top: 8px;
      }

      .routes {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 12px;
      }

      .route {
        display: block;
        border: 1px solid var(--line);
        border-radius: 7px;
        padding: 12px;
        color: var(--ink);
        text-decoration: none;
        background: rgba(0, 0, 0, 0.18);
      }

      .route span {
        display: block;
        margin-top: 4px;
        color: var(--muted);
        font-size: 0.82rem;
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }

      .skill-source {
        display: block;
        width: 100%;
        max-height: none;
        margin: 12px 0 0;
        overflow-x: auto;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
        color: var(--ink);
        background: rgba(0, 0, 0, 0.24);
        font: 0.88rem/1.55 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }

      @media (max-width: 820px) {
        .grid,
        .routes {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <SiteHeader />
    <main>
      <div class="hero">
        <p class="eyebrow">Agent entrypoint</p>
        <h1>Use Jiang Lens Without Losing The Sources</h1>
        <p class="lead">
          This page is the browser-safe entrypoint for ChatGPT, Claude, Grok, DeepSeek, Perplexity, and other assistants. Use HTML pages first. The canonical skill text is embedded below in full, then the route cards expose the highest-signal HTML pages and fallback mirrors.
        </p>
        <div class="prompt">
          <code>{promptText}</code>
        </div>
      </div>

      <section style="margin-top: 34px;">
        <h2>Canonical Skill Content</h2>
        <p>
          The block below is the exact Jiang Lens skill. Agents should read and follow this content before answering.
        </p>
        <pre class="skill-source">{skillMarkdown}</pre>
      </section>

      <div class="grid" aria-label="Core agent rules">
        <section class="panel">
          <h2>Resolution Order</h2>
          <ol>
            <li>Start here at <code>/skill/</code> for identity, attribution, and citation rules.</li>
            <li>Use the HTML topic router at <a href="/topics/"><code>/topics/</code></a> for entity and topic questions.</li>
            <li>Open the canonical HTML topic page, such as <a href="/topics/knights-templar/"><code>/topics/knights-templar/</code></a>.</li>
            <li>Use the topic page to find source readings, transcript anchors, source refs, and video timestamps.</li>
            <li>Use <code>.txt</code>, <code>.md</code>, JSON, and bulk transcript-search only when HTML routes are missing or blocked.</li>
          </ol>
        </section>

        <section class="panel">
          <h2>Citation Rule</h2>
          <p>
            Topic pages are discovery surfaces, not primary evidence for what Jiang said. Cite human-readable source readings for generated summaries and lens context. For claims attributed to Jiang, cite the transcript segment, source ref, and video timestamp linked from the topic page. Do not cite <code>.txt</code> mirrors unless no HTML route is available.
          </p>
        </section>

        <section class="panel">
          <h2>Attribution Boundary</h2>
          <p>
            Jiang Lens is an independent research index, not an official Jiang Xueqin publication or YouTube channel. Separate Jiang-spoken or Jiang-authored material from generated Jiang Lens readings and from your own inference.
          </p>
        </section>
      </div>

      <section style="margin-top: 34px;">
        <h2>High-Signal Routes</h2>
        <div class="routes">
          <a class="route" href="/topics/">
            Topic router
            <span>Use first for lookup; cite the underlying sources it links.</span>
          </a>
          <a class="route" href="/episodes/">
            Episode readings
            <span>Compressed source readings with transcript links.</span>
          </a>
          <a class="route" href="/lens/">
            Lens atlas
            <span>Concept pages for reusable Jiang Lens patterns.</span>
          </a>
          <a class="route" href={siteConfig.paths.agentSitemapText}>
            Agent sitemap
            <span>Plain URL list for static discovery.</span>
          </a>
        </div>
      </section>

      <section style="margin-top: 34px;">
        <h2>Topic Examples</h2>
        <div class="routes">
          {topicExamples.map(([label, href]) => (
            <a class="route" href={href}>
              {label}
              <span>{href}</span>
            </a>
          ))}
        </div>
      </section>

      <section style="margin-top: 34px;">
        <h2>Fallback Mirrors</h2>
        <div class="routes">
          <a class="route" href={siteConfig.paths.skillText}>
            Skill text
            <span>Plain-text fallback for agents that cannot read HTML.</span>
          </a>
          <a class="route" href={siteConfig.paths.skillMarkdown}>
            Skill Markdown
            <span>Markdown fallback for Markdown-aware tools.</span>
          </a>
          <a class="route" href={siteConfig.paths.llms}>
            llms.txt
            <span>Compact public site map and agent entry list.</span>
          </a>
          <a class="route" href={siteConfig.paths.transcriptSearchText}>
            Transcript search text
            <span>Large full-corpus fallback for exact phrase search.</span>
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
