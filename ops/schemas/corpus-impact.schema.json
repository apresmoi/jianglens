{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jianglens.local/schemas/corpus-impact.schema.json",
  "title": "Jiang Lens Corpus Impact Pass",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_slug",
    "source_title",
    "source_date",
    "source_ref_base",
    "impact_level",
    "summary",
    "existing_lens_links",
    "concept_extensions",
    "new_lens_seeds",
    "atlas_mutations",
    "chronology_notes",
    "canon_candidates",
    "next_actions"
  ],
  "properties": {
    "source_slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "source_title": { "type": "string", "minLength": 1 },
    "source_date": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "source_ref_base": {
      "type": "string",
      "pattern": "^video:[a-z0-9][a-z0-9-]*@transcript:v[0-9]+$"
    },
    "impact_level": {
      "type": "string",
      "enum": [
        "evidence-only",
        "link-existing-lens",
        "extend-existing-concept",
        "create-new-lens-seed",
        "morph-atlas-structure",
        "canon-candidate"
      ]
    },
    "summary": { "type": "string", "minLength": 1 },
    "existing_lens_links": { "type": "array", "items": { "type": "object" } },
    "concept_extensions": { "type": "array", "items": { "type": "object" } },
    "new_lens_seeds": { "type": "array", "items": { "type": "object" } },
    "atlas_mutations": { "type": "array", "items": { "type": "object" } },
    "chronology_notes": { "type": "array", "items": { "type": "object" } },
    "canon_candidates": { "type": "array", "items": { "type": "object" } },
    "next_actions": { "type": "array", "items": { "type": "string" } }
  }
}
