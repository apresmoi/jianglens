# Copy to ops/secrets/episode-worker.env and fill in real values.
# ops/secrets/ is gitignored.

# Fine-grained GitHub token for apresmoi/jianglens.
# Required scopes: Contents read/write, Pull requests read/write, Metadata read.
GH_TOKEN=

# Optional checkout overrides. Defaults shown here are used by the container.
# JIANG_LENS_REPO_URL=https://github.com/apresmoi/jianglens.git
# JIANG_LENS_REPO_BRANCH=main
# JIANG_LENS_REPO_DIR=/var/lib/spawnfile/instances/picoclaw/agent-episode-worker/picoclaw/workspace/jiang-lens

# Optional Picoclaw cron controls. The agents can adjust their own native
# Picoclaw cron jobs after startup; these values only seed the default jobs.
# EPISODE_WORKER_CRON_INTERVAL_SECONDS=86400
# EPISODE_WORKER_STATE_DIR=/var/lib/spawnfile/instances/picoclaw/agent-episode-worker/picoclaw/state/episode-worker
#
# Plato / lens steward cron controls.
# LENS_STEWARD_CRON_INTERVAL_SECONDS=7200
# LENS_STEWARD_REPO_DIR=/var/lib/spawnfile/instances/picoclaw/agent-lens-steward/picoclaw/workspace/jiang-lens
# LENS_STEWARD_STATE_DIR=/var/lib/spawnfile/instances/picoclaw/agent-lens-steward/picoclaw/state/lens-steward
#
# Picoclaw heartbeat remains disabled. Scheduled production work uses
# Picoclaw's native cron service, stored under the persisted workspace/cron
# folders mounted by ops/scripts/run-episode-worker-stack.mjs.
