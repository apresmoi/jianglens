spawnfile_version: "0.1"
kind: agent
name: lens-steward
description: "Plato: stewards the processed Jiang corpus into source-grounded lens concepts, atlas structure, and evidence-linked public pages."

runtime:
  name: picoclaw
  options:
    restrict_to_workspace: true

execution:
  model:
    auth:
      method: codex
    primary:
      provider: openai
      name: gpt-5.5
  workspace:
    isolation: shared
  sandbox:
    mode: workspace

surfaces:
  moltnet:
    - network: local_lab
      rooms:
        episode-floor:
          read: all
          reply: never

docs:
  identity: IDENTITY.md
  soul: SOUL.md
  system: AGENTS.md
  memory: MEMORY.md
  heartbeat: HEARTBEAT.md
  extras:
    setup: SETUP.md
    state: STATE.md

policy:
  mode: warn
  on_degrade: warn
