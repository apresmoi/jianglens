spawnfile_version: "0.1"
kind: agent
name: aristotle
description: "Aristotle: reviews episode and interview PRs against transcripts before source auto-merge."

runtime:
  name: picoclaw
  options:
    restrict_to_workspace: true

execution:
  model:
    primary:
      provider: openai
      name: gpt-5.5
      auth:
        method: codex
  sandbox:
    mode: workspace

schedule:
  kind: cron
  cron: "20,50 * * * *"
  timezone: UTC
  prompt: "Wake as Aristotle. Read generated workspace context, enter ./repos/jiang-lens, inspect open episode/interview PRs and recent episode-floor handoffs, then review at most one source PR for transcript-grounded public-read quality."

surfaces:
  moltnet:
    - network: local_lab
      rooms:
        episode-floor:
          read: mentions
          reply: auto

workspace:
  docs:
    identity: IDENTITY.md
    soul: SOUL.md
    system: AGENTS.md
    memory: MEMORY.md
    heartbeat: HEARTBEAT.md
    extras:
      setup: SETUP.md
      state: STATE.md
  resources:
    - id: aristotle-state
      kind: volume
      mount: ./state
      mode: mutable
