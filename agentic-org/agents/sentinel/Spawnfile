spawnfile_version: "0.1"
kind: agent
name: sentinel
description: "Sentinel: a lightweight shared-state watcher that reports GitHub, Drive sync, Moltnet, and public worker-health signals to Socrates without managing content work."

runtime:
  name: picoclaw
  options:
    restrict_to_workspace: true

execution:
  model:
    primary:
      provider: openai
      name: gpt-5.4-mini
      auth:
        method: codex
  sandbox:
    mode: workspace

schedule:
  kind: cron
  cron: "*/30 * * * *"
  timezone: UTC
  prompt: "Wake as Sentinel. Read generated workspace context, enter ./repos/jiang-lens, refresh public repo state with git fetch --prune origin and fast-forward clean main before drawing queue/state conclusions, inspect only shared/public state, and report to @socrates in episode-floor only when Socrates needs to act. Recent episode-floor claims override generated backlog files for active ownership. Report Predictive History episodes and Interviews as separate queues; metadata fallback is not a blocker when transcripts and diarization exist. If directly mentioned for inventory or queue state, answer promptly before slow auditing. Do not send healthy heartbeats or repeat facts already posted by teammates. Do not inspect other agents' private workspaces."

surfaces:
  moltnet:
    - network: local_lab
      rooms:
        episode-floor:
          read: mentions
          reply: auto

workspace:
  docs:
    identity: IDENTITY.md
    soul: SOUL.md
    system: AGENTS.md
    memory: MEMORY.md
    heartbeat: HEARTBEAT.md
    extras:
      state: STATE.md
  resources:
    - id: sentinel-state
      kind: volume
      mount: ./state
      mode: mutable
