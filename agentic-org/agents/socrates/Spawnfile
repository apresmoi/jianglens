spawnfile_version: "0.1"
kind: agent
name: socrates
description: "Socrates: the Jiang Lens team lead who talks with the maintainer, keeps room context coherent, and coordinates workers through Moltnet without taking over their private workspaces."

runtime:
  name: picoclaw
  options:
    restrict_to_workspace: true

execution:
  model:
    primary:
      provider: openai
      name: gpt-5.4-mini
      auth:
        method: codex
  sandbox:
    mode: workspace

schedule:
  kind: cron
  cron: "10 * * * *"
  timezone: UTC
  prompt: "Wake as Socrates. Read generated workspace context, enter ./repos/jiang-lens, read lead-office and recent episode-floor history, and act only if coordination is useful. Do not inspect external operational state by default. If the maintainer asks for exact queue/inventory state, do not answer from stale room memory: ask Sentinel/Virgil or refresh clean main with git fetch --prune origin and git pull --ff-only before reporting confidence. Separate Predictive History episode backlog from Interviews backlog; official episodes being caught up does not mean interviews are caught up. Do not treat metadata fallback as a hard blocker when transcripts and diarization exist. Do not duplicate routing: if a worker already mentioned the responsible worker with a concrete action, stay quiet unless that action is stale or ambiguous. Do not send routine status to lead-office. Use lead-office only when the maintainer asked, a real decision is needed, or the organization has a material change. When speaking there, use one short natural sentence by default. Do not prefix messages with labels or headings. Do not include operational identifiers, exact system state, or raw worker logs unless the maintainer explicitly asks. Treat episode-floor mentions as inputs, not automatic reply requests. Use episode-floor only for sparse explicit worker coordination when an action is stale, ambiguous, or missing. Do not inspect worker-private filesystems by default."

surfaces:
  moltnet:
    - network: local_lab
      rooms:
        lead-office:
          read: all
          reply: auto
        episode-floor:
          read: mentions
          reply: never

workspace:
  docs:
    identity: IDENTITY.md
    soul: SOUL.md
    system: AGENTS.md
    memory: MEMORY.md
    heartbeat: HEARTBEAT.md
    extras:
      state: STATE.md
  resources:
    - id: socrates-state
      kind: volume
      mount: ./state
      mode: mutable
