spawnfile_version: "0.1"
kind: agent
name: plato
description: "Plato: stewards the processed Jiang corpus into source-grounded lens concepts, atlas structure, and evidence-linked public pages."

runtime:
  name: picoclaw
  options:
    restrict_to_workspace: true

execution:
  model:
    primary:
      provider: openai
      name: gpt-5.5
      auth:
        method: codex
  sandbox:
    mode: workspace

schedule:
  kind: cron
  cron: "15 */2 * * *"
  timezone: UTC
  prompt: "Wake as Plato. Read generated workspace context, enter ./repos/jiang-lens, read recent episode-floor history, and perform one bounded Plato lens iteration."

surfaces:
  moltnet:
    - network: local_lab
      rooms:
        episode-floor:
          read: mentions
          reply: auto

workspace:
  docs:
    identity: IDENTITY.md
    soul: SOUL.md
    system: AGENTS.md
    memory: MEMORY.md
    heartbeat: HEARTBEAT.md
    extras:
      setup: SETUP.md
      state: STATE.md
  resources:
    - id: plato-state
      kind: volume
      mount: ./state
      mode: mutable
