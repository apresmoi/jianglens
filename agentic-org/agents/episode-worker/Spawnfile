spawnfile_version: "0.1"
kind: agent
name: episode-worker
description: "Virgil: processes one ready Jiang Lens video into a public website-visible episode or interview."

runtime:
  name: picoclaw
  options:
    restrict_to_workspace: true

execution:
  model:
    primary:
      provider: openai
      name: gpt-5.5
      auth:
        method: codex
  sandbox:
    mode: workspace

schedule:
  kind: cron
  cron: "0 5 * * *"
  timezone: UTC
  prompt: Wake as Virgil. Read generated workspace context, enter
    ./repos/jiang-lens, read recent episode-floor history, and perform one
    bounded episode-worker iteration.

workspace:
  docs:
    identity: IDENTITY.md
    soul: SOUL.md
    system: AGENTS.md
    memory: MEMORY.md
    heartbeat: HEARTBEAT.md
    extras:
      setup: SETUP.md
      state: STATE.md
  resources:
    - id: episode-worker-state
      kind: volume
      mount: ./state
      mode: mutable

surfaces:
  moltnet:
    - network: local_lab
      rooms:
        episode-floor:
          read: mentions
          reply: auto
