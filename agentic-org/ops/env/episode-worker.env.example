# Copy to ops/secrets/episode-worker.env and fill in real values.
# ops/secrets/ is gitignored.

# Fine-grained GitHub token for apresmoi/jianglens.
# Required scopes: Contents read/write, Pull requests read/write, Metadata read.
GH_TOKEN=

# Local Moltnet console/operator token.
# Required for human console send access on Moltnet 0.1.4+ when auth.mode is open.
# Generate with: openssl rand -hex 32
MOLTNET_OPERATOR_TOKEN=

# Optional Picoclaw cron controls. The agents can adjust their own native
# Picoclaw cron jobs after startup; these values only seed the default jobs.
# EPISODE_WORKER_CRON_INTERVAL_SECONDS=86400
#
# Plato / lens steward cron controls.
# LENS_STEWARD_CRON_INTERVAL_SECONDS=7200
#
# Picoclaw heartbeat remains disabled. Scheduled production work uses
# Picoclaw's native cron service, stored under the persisted workspace/cron
# folders mounted by ops/scripts/run-episode-worker-stack.mjs until Spawnfile
# lowers schedule declarations into Picoclaw cron storage.
