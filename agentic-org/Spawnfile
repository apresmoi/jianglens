spawnfile_version: "0.1"
kind: team
name: jiang-lens-agents
description: "Autonomous PicoClaw workers for turning the Jiang corpus into website-visible episodes, source-grounded public lens work, quality review, and lightweight organizational coordination."

shared:
  workspace:
    docs:
      system: TEAM.md
    resources:
      - id: jiang-lens-repo
        kind: git
        url: https://github.com/apresmoi/jianglens.git
        branch: main
        mount: ./repos/jiang-lens
        mode: mutable
    skills:
      - ref: ../.codex/skills/moltnet
      - ref: ../.codex/skills/jiang-autonomous-work-protocol
      - ref: ../.codex/skills/jiang-source-ingest
      - ref: ../.codex/skills/jiang-transcript-boundary-review
      - ref: ../.codex/skills/jiang-agent-transcript-pass
      - ref: ../.codex/skills/jiang-video-e2e
      - ref: ../.codex/skills/jiang-episode-read-writer
      - ref: ../.codex/skills/jiang-episode-publisher
      - ref: ../.codex/skills/jiang-episode-quality-review
      - ref: ../.codex/skills/jiang-corpus-impact-pass
      - ref: ../.codex/skills/jiang-lens-distillation
      - ref: ../.codex/skills/jiang-lens-concept-writer
      - ref: ../.codex/skills/jiang-lens-atlas-maintainer
      - ref: ../.codex/skills/jiang-provenance-linker
      - ref: ../.codex/skills/jiang-lens-judge
      - ref: ../.codex/skills/jiang-canon-promotion
  environment:
    env:
      GIT_AUTHOR_NAME: Jiang Lens Agents
      GIT_AUTHOR_EMAIL: agents@jianglens.local
      GIT_COMMITTER_NAME: Jiang Lens Agents
      GIT_COMMITTER_EMAIL: agents@jianglens.local
    secrets:
      - name: GH_TOKEN
        required: true
      - name: MOLTNET_AGENT_TOKEN
        required: true
      - name: MOLTNET_OPERATOR_TOKEN
        required: true
    packages:
      - id: github-cli
        manager: apt
        name: gh
      - id: yt-dlp
        manager: pipx
        name: yt-dlp
      - id: node-22
        manager: npm
        name: node
        scope: global
        version: 22.12.0
      - id: codex-cli
        manager: npm
        name: "@openai/codex"
        scope: global
        version: 0.128.0

networks:
  - id: local_lab
    provider: moltnet
    name: Jiang Lens Local Lab
    server:
      mode: managed
      listen:
        bind: 0.0.0.0
        port: 8787
      auth:
        mode: bearer
        public_read: true
        agent_registration: disabled
        client:
          token_id: agent-attachments
        tokens:
          - id: agent-attachments
            secret: MOLTNET_AGENT_TOKEN
            scopes:
              - observe
              - write
              - attach
            agents:
              - socrates
              - sentinel
              - virgil
              - aristotle
              - plato
          - id: operator-console
            secret: MOLTNET_OPERATOR_TOKEN
            scopes:
              - observe
              - write
              - admin
      store:
        kind: sqlite
        persistence:
          mode: durable
      human_ingress: true
      direct_messages: false
      trust_forwarded_proto: true
      allowed_origins:
        - https://moltnet.jianglens.com
        - http://178.104.47.56:8787
    rooms:
      - id: episode-floor
        name: Episode Floor
        visibility: public
        write_policy: members
        members:
          - socrates
          - sentinel
          - virgil
          - aristotle
          - plato
      - id: lead-office
        name: Lead Office
        visibility: private
        write_policy: members
        members:
          - socrates

members:
  - id: virgil
    ref: ./agents/virgil
  - id: plato
    ref: ./agents/plato
  - id: socrates
    ref: ./agents/socrates
  - id: sentinel
    ref: ./agents/sentinel
  - id: aristotle
    ref: ./agents/aristotle
mode: hierarchical
lead: socrates
