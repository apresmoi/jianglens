spawnfile_version: "0.1"
kind: team
name: jiang-lens-agents
description: "Autonomous PicoClaw workers for turning the Jiang corpus into website-visible episodes and a source-grounded public lens."

mode: swarm

shared:
  workspace:
    docs:
      system: TEAM.md
    resources:
      - id: jiang-lens-repo
        kind: git
        url: https://github.com/apresmoi/jianglens.git
        branch: main
        mount: ./repos/jiang-lens
        mode: mutable
    skills:
      - ref: ../.codex/skills/moltnet
      - ref: ../.codex/skills/jiang-autonomous-work-protocol
      - ref: ../.codex/skills/jiang-source-ingest
      - ref: ../.codex/skills/jiang-transcript-boundary-review
      - ref: ../.codex/skills/jiang-agent-transcript-pass
      - ref: ../.codex/skills/jiang-video-e2e
      - ref: ../.codex/skills/jiang-episode-read-writer
      - ref: ../.codex/skills/jiang-episode-publisher
      - ref: ../.codex/skills/jiang-corpus-impact-pass
      - ref: ../.codex/skills/jiang-lens-distillation
      - ref: ../.codex/skills/jiang-lens-concept-writer
      - ref: ../.codex/skills/jiang-lens-atlas-maintainer
      - ref: ../.codex/skills/jiang-provenance-linker
      - ref: ../.codex/skills/jiang-lens-judge
      - ref: ../.codex/skills/jiang-canon-promotion
  environment:
    env:
      GIT_AUTHOR_NAME: "Jiang Lens Agents"
      GIT_AUTHOR_EMAIL: "agents@jianglens.local"
      GIT_COMMITTER_NAME: "Jiang Lens Agents"
      GIT_COMMITTER_EMAIL: "agents@jianglens.local"
    secrets:
      - name: GH_TOKEN
        required: true
      - name: MOLTNET_OPERATOR_TOKEN
        required: true
    packages:
      - id: github-cli
        manager: apt
        name: gh
      - id: yt-dlp
        manager: pipx
        name: yt-dlp
      - id: node-22
        manager: npm
        name: node
        version: "22.12.0"
        scope: global
      - id: codex-cli
        manager: npm
        name: "@openai/codex"
        version: "0.128.0"
        scope: global

members:
  - id: episode-worker
    ref: ./agents/episode-worker
  - id: lens-steward
    ref: ./agents/lens-steward

networks:
  - id: local_lab
    name: Jiang Lens Local Lab
    provider: moltnet
    server:
      mode: managed
      listen:
        bind: 0.0.0.0
        port: 8787
      human_ingress: true
      direct_messages: false
      store:
        kind: sqlite
        persistence:
          mode: durable
      auth:
        mode: open
        tokens:
          - id: operator-console
            secret: MOLTNET_OPERATOR_TOKEN
            scopes: [observe, write, admin]
    rooms:
      - id: episode-floor
        name: Episode Floor
        members: [episode-worker, lens-steward]
